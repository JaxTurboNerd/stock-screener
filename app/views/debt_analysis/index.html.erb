<div class='flex flex-col items-center w-full p-5 bg-white dark:bg-gray-900 min-h-screen'>
  <h1 class='text-4xl text-gray-900 dark:text-white mb-8'>Debt Analysis</h1>

  <% if flash[:alert] %>
    <div class='w-full max-w-md mb-6 p-4 rounded-lg bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-200'>
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: debt_analysis_analyze_path, method: :post, local: true,
        data: { turbo: false, controller: "upload-form", action: "submit->upload-form#submit" },
        class: "w-full max-w-md" do |form| %>

    <label for='ticker_input' class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'>
      Stock Ticker Symbol
    </label>
    <%= form.text_field :ticker,
          id: "ticker_input",
          maxlength: 5,
          placeholder: "e.g. AAPL",
          value: @ticker,
          class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 uppercase focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 text-lg tracking-widest mb-1" %>
    <p class='text-xs text-gray-500 dark:text-gray-400 mb-4'>Maximum 5 characters</p>

    <div class="flex flex-col items-start gap-2">
      <%= form.submit "Analyze Debt Profile",
            data: { upload_form_target: "button" },
            class: "px-6 py-3 bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 transition-colors font-semibold cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed" %>
      <p data-upload-form-target="status" class="hidden text-sm text-gray-500 dark:text-gray-400 animate-pulse">
        Contacting Perplexity AI &mdash; this may take 10&ndash;20 seconds&hellip;
      </p>
    </div>
  <% end %>

  <% if @analysis %>
    <div class="w-full max-w-3xl mt-12 space-y-6">

      <%# Header: company name + profitability badge %>
      <div class="flex flex-wrap items-center gap-4">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          <%= @analysis['company_name'] %>
          <span class="text-gray-400 dark:text-gray-500 font-normal text-lg ml-1">(<%= @analysis['ticker'] %>)</span>
        </h2>
        <% if @analysis['profitable'] %>
          <span class="px-3 py-1 rounded-full text-sm font-semibold bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
            &#10003; Profitable
          </span>
        <% else %>
          <span class="px-3 py-1 rounded-full text-sm font-semibold bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
            &#10007; Not Profitable
          </span>
        <% end %>
        <% debt_rating_tooltip = case @analysis['debt_rating']
             when /Investment Grade/i
               "Debt Rating — The company's debt is considered low-risk. It demonstrates strong capacity to meet financial obligations, typically reflected by a BBB− or higher credit rating."
             when /Speculative/i
               "Debt Rating — Also known as 'high yield' or 'junk' status. The company carries elevated credit risk and may face difficulty servicing debt if earnings or market conditions deteriorate."
             when /Not Rated/i
               "Debt Rating — No formal credit rating has been assigned. Common for smaller companies or those without coverage from major credit rating agencies."
             else
               "Debt Rating — An AI-assessed indicator of the company's ability to service its debt obligations based on available financial data."
             end %>
        <div class="relative group inline-flex">
          <span class="px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 cursor-default">
            <%= @analysis['debt_rating'] %>
          </span>
          <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-72 rounded-lg bg-gray-900 dark:bg-gray-950 text-white text-xs leading-relaxed px-3 py-2 shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-150 z-10">
            <%= debt_rating_tooltip %>
            <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900 dark:border-t-gray-950"></div>
          </div>
        </div>
        <% if @analysis['sector'].present? %>
          <span class="px-3 py-1 rounded-full text-sm font-semibold bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300">
            <%= @analysis['sector'] %>
          </span>
        <% end %>
      </div>

      <% if @analysis['data_period'].present? %>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Data period: <%= @analysis['data_period'] %></p>
      <% end %>

      <p class="text-gray-600 dark:text-gray-400 italic"><%= @analysis['profitability_summary'] %></p>

      <%# Metrics grid %>
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Key Metrics</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <% metric_labels = {
               "total_debt"       => "Total Debt",
               "profit_margin"    => "Profit Margin",
               "return_on_equity" => "Return on Equity",
               "debt_to_equity"   => "Debt / Equity",
               "current_ratio"    => "Current Ratio",
               "free_cash_flow"   => "Free Cash Flow"
             } %>
          <% metric_tooltips = {
               "profit_margin"    => "How much of each dollar of revenue the company keeps as profit after all expenses, interest, and taxes. A higher margin generally indicates better cost control and pricing power.",
               "return_on_equity" => "Profitability from the shareholders' perspective – how effectively the company uses owners' equity to generate earnings. Higher ROE (sustainably achieved) typically signals efficient use of capital.",
               "debt_to_equity"   => "Long‑term solvency and leverage – how much the company relies on debt versus owners' equity to finance its assets. Higher levels mean more financial risk if earnings fall.",
               "current_ratio"    => "Short‑term liquidity – whether the company has enough current assets to cover obligations due within a year. Values well below 1 can signal potential cash‑flow stress.",
               "free_cash_flow"   => "Cash the business generates after funding operations and required capital expenditures, which can be used to pay down debt, repurchase shares, or pay dividends. Strong and growing FCF is a key sign of underlying financial health."
             } %>
          <% metric_labels.each do |key, label| %>
            <% tooltip = metric_tooltips[key] %>
            <% card_bg = if key == "profit_margin"
                           case @analysis["profit_margin_rating"]
                           when "good"    then "bg-green-50 dark:bg-green-900/30 ring-1 ring-green-200 dark:ring-green-800"
                           when "average" then "bg-amber-50 dark:bg-amber-900/30 ring-1 ring-amber-200 dark:ring-amber-700"
                           when "bad"     then "bg-red-50 dark:bg-red-900/30 ring-1 ring-red-200 dark:ring-red-800"
                           else                "bg-white dark:bg-gray-700"
                           end
                         elsif key == "current_ratio"
                           cr_str = @analysis&.dig('metrics', 'current_ratio')
                           if cr_str.present? && cr_str != '—'
                             cr_val = cr_str.to_f
                             if cr_val < 1.0
                               "bg-red-50 dark:bg-red-900/30 ring-1 ring-red-200 dark:ring-red-800"
                             elsif cr_val < 1.5
                               "bg-amber-50 dark:bg-amber-900/30 ring-1 ring-amber-200 dark:ring-amber-700"
                             else
                               "bg-green-50 dark:bg-green-900/30 ring-1 ring-green-200 dark:ring-green-800"
                             end
                           else
                             "bg-white dark:bg-gray-700"
                           end
                         elsif key == "return_on_equity"
                           roe_str = @analysis&.dig('metrics', 'return_on_equity')
                           if roe_str.present? && roe_str != '—'
                             roe_val = roe_str.to_f
                             if roe_val >= 15.0
                               "bg-green-50 dark:bg-green-900/30 ring-1 ring-green-200 dark:ring-green-800"
                             elsif roe_val >= 5.0
                               "bg-amber-50 dark:bg-amber-900/30 ring-1 ring-amber-200 dark:ring-amber-700"
                             else
                               "bg-red-50 dark:bg-red-900/30 ring-1 ring-red-200 dark:ring-red-800"
                             end
                           else
                             "bg-white dark:bg-gray-700"
                           end
                         elsif key == "debt_to_equity"
                           de_str = @analysis&.dig('metrics', 'debt_to_equity')
                           if de_str.present? && de_str != '—'
                             de_val = de_str.to_f
                             if de_val <= 1.5
                               "bg-green-50 dark:bg-green-900/30 ring-1 ring-green-200 dark:ring-green-800"
                             elsif de_val <= 2.5
                               "bg-amber-50 dark:bg-amber-900/30 ring-1 ring-amber-200 dark:ring-amber-700"
                             else
                               "bg-red-50 dark:bg-red-900/30 ring-1 ring-red-200 dark:ring-red-800"
                             end
                           else
                             "bg-white dark:bg-gray-700"
                           end
                         else
                           "bg-white dark:bg-gray-700"
                         end %>
            <div class="relative group <%= card_bg %> rounded-lg p-3 shadow-sm">
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1 flex items-center gap-1">
                <%= label %>
                <% if tooltip %>
                  <span class="inline-flex items-center justify-center w-3.5 h-3.5 rounded-full bg-gray-200 dark:bg-gray-600 text-gray-500 dark:text-gray-400 text-[9px] font-bold leading-none cursor-default select-none">?</span>
                <% end %>
              </p>
              <p class="text-base font-semibold text-gray-900 dark:text-white">
                <%= @analysis.dig('metrics', key) || '—' %>
              </p>
              <% if tooltip %>
                <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 rounded-lg bg-gray-900 dark:bg-gray-950 text-white text-xs leading-relaxed px-3 py-2 shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-150 z-10">
                  <%= tooltip %>
                  <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900 dark:border-t-gray-950"></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <%# AI narrative %>
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Analysis</h3>
        <div class="text-gray-700 dark:text-gray-300 space-y-3 leading-relaxed">
          <% @analysis['analysis'].to_s.split(/\n\n+/).each do |para| %>
            <p><%= para.strip %></p>
          <% end %>
        </div>
      </div>

    </div>
  <% end %>
</div>
